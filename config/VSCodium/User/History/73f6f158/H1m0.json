{
    // Menyembunyikan elemen UI utama
    "workbench.activityBar.visible": false, // Menghilangkan bar ikon di kiri
    "workbench.statusBar.visible": false, // Menghilangkan bar biru/ungu di bawah
    "workbench.sideBar.location": "left",
    "workbench.editor.showTabs": "none", // Menghilangkan tab (navigasi via H/L atau Telescope)
    "editor.minimap.enabled": false, // Menghilangkan peta kode di kanan
    "editor.scrollbar.vertical": "hidden", // Menghilangkan scrollbar
    "editor.glyphMargin": false, // Menghilangkan margin untuk breakpoint
    "editor.folding": false, // Menghilangkan ikon lipat kode
    // Breadcrumbs (navigasi struktur file di atas editor)
    "breadcrumbs.enabled": false,
    // Membuat tampilan editor lebih luas
    "workbench.layoutControl.enabled": false,
    "editor.lineNumbers": "relative", // Tetap aktifkan untuk navigasi Vim
    // --- VIM CORE CONFIGURATION ---
    "vim.leader": "<space>",
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.easymotion": true,
    "vim.sneak": true,
    "vim.useCtrlKeys": true,
    // --- KEYBINDINGS (NORMAL MODE) ---
    "vim.normalModeKeyBindingsNonRecursive": [
        // Navigasi Editor (Buffer)
        {
            "before": [
                "L"
            ],
            "commands": [
                "workbench.action.nextEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "f",
                "f"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "<leader>",
                "x"
            ],
            "commands": [
                "workbench.action.closeActiveEditor"
            ]
        },
        {
            "before": [
                "H"
            ],
            "commands": [
                "workbench.action.previousEditor"
            ]
        },
        // Window Management (Splits)
        {
            "before": [
                "<leader>",
                "v"
            ],
            "commands": [
                "workbench.action.splitEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "s"
            ],
            "commands": [
                "workbench.action.splitEditorDown"
            ]
        },
        // File & Terminal Management
        {
            "before": [
                "<leader>",
                "e"
            ],
            "commands": [
                "workbench.view.explorer"
            ]
        },
        {
            "before": [
                "<leader>",
                "t"
            ],
            "commands": [
                "workbench.action.terminal.toggleTerminal"
            ]
        },
        {
            "before": [
                "<leader>",
                "w"
            ],
            "commands": [
                ":w!"
            ]
        },
        {
            "before": [
                "<leader>",
                "q"
            ],
            "commands": [
                ":q!"
            ]
        },
        {
            "before": [
                "<leader>",
                "h"
            ],
            "commands": [
                ":noh"
            ]
        }
    ],
    // --- INSERT MODE QUICK ESCAPE ---
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "j"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    // --- TERMINAL BEHAVIOR ---
    // Memastikan Ctrl di terminal tidak bentrok dengan Vim mode
    "terminal.integrated.sendKeybindingsToShell": true,
    "terminal.integrated.cursorStyle": "line",
    // --- UI & AESTHETICS (Minimalist) ---
    "editor.fontFamily": "'SFMono Nerd Font', 'Fira Code'",
    "editor.fontSize": 14,
    "editor.cursorStyle": "block",
    "editor.cursorBlinking": "solid",
    "workbench.startupEditor": "none",
    // --- FILE SPECIFIC (Optional) ---
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true
}
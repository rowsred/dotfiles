#!/bin/bash

# --- Warna untuk UI ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' 
BOLD='\033[1m'

# --- Konfigurasi ---
# Mengatur repo ke satu folder di atas folder 'bin'
DOTFILES_REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_SRC="$HOME/.config"
CONFIG_DEST="$DOTFILES_REPO/config"

HOME_FILES=(
    ".bashrc:bashrc"
    ".zshrc:zshrc"
    ".vimrc:vimrc"
    ".gitconfig:gitconfig"
)

header() {
    clear
    echo -e "${BLUE}${BOLD}==========================================${NC}"
    echo -e "${BLUE}${BOLD}   🚀 DOTFILES MANAGER (Rsync Edition)    ${NC}"
    echo -e "${BLUE}${BOLD}==========================================${NC}"
}

print_status() {
    local status=$1
    local message=$2
    case $status in
        "info") echo -e "${BLUE}[INFO]${NC} $message" ;;
        "success") echo -e "${GREEN}[OK]${NC} $message" ;;
        "warn") echo -e "${YELLOW}[WARN]${NC} $message" ;;
        "error") echo -e "${RED}[ERROR]${NC} $message" ;;
    esac
}

backup() {
    header
    print_status "info" "Backup ke: ${BOLD}$DOTFILES_REPO${NC}"
    mkdir -p "$CONFIG_DEST"

    echo -e "\n${BOLD}1. Sync Folder .config${NC}"
    echo "----------------------------------------------------"
    
    # Loop melalui folder di .config untuk tampilan yang rapi
    for dir in "$CONFIG_SRC"/*/; do
        folder_name=$(basename "$dir")
        # Proses rsync diam-diam (-q)
        rsync -az --delete "$dir" "$CONFIG_DEST/$folder_name"
        printf "  %-30s ${GREEN}✔️ Synced${NC}\n" "$folder_name"
    done

    echo -e "\n${BOLD}2. Sync File Home (Renaming)${NC}"
    echo "----------------------------------------------------"
    for entry in "${HOME_FILES[@]}"; do
        src="${entry%%:*}"
        dest="${entry#*:}"
        if [ -f "$HOME/$src" ]; then
            rsync -az "$HOME/$src" "$DOTFILES_REPO/$dest"
            printf "  %-30s ${GREEN}✔️ %-20s${NC}\n" "$src" "$dest"
        else
            printf "  %-30s ${RED}❌ Not Found${NC}\n" "$src"
        fi
    done
    echo -e "\n${GREEN}${BOLD}✨ BACKUP SELESAI!${NC}\n"
}

restore() {
    header
    print_status "info" "Memulihkan konfigurasi ke sistem..."

    echo -e "\n${BOLD}1. Memulihkan .config${NC}"
    echo "----------------------------------------------------"
    for dir in "$CONFIG_DEST"/*/; do
        folder_name=$(basename "$dir")
        rsync -az "$dir" "$CONFIG_SRC/$folder_name"
        printf "  %-30s ${GREEN}✔️ Restored${NC}\n" "$folder_name"
    done

    echo -e "\n${BOLD}2. Memulihkan file Home (Restore dots)${NC}"
    echo "----------------------------------------------------"
    for entry in "${HOME_FILES[@]}"; do
        src="${entry%%:*}"
        dest="${entry#*:}"
        if [ -f "$DOTFILES_REPO/$dest" ]; then
            rsync -az "$DOTFILES_REPO/$dest" "$HOME/$src"
            printf "  %-30s ${GREEN}✔️ %-20s${NC}\n" "$dest" "$src"
        else
            printf "  %-30s ${RED}❌ Missing${NC}\n" "$dest"
        fi
    done
    echo -e "\n${GREEN}${BOLD}✅ RESTORE SELESAI!${NC}\n"
}

case "$1" in
    backup)  backup ;;
    restore) restore ;;
    *)       
        header
        echo -e "Usage: $0 {${GREEN}backup${NC}|${YELLOW}restore${NC}}"
        exit 1
        ;;
esac

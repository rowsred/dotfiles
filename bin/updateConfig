#!/bin/bash

# --- Warna untuk UI ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'

# --- Konfigurasi Path ---
# Mendapatkan path absolut folder dotfiles (asumsi script ada di dalam repo)
DOTFILES_REPO="$HOME/dotfiles"
CONFIG_SRC="$HOME/.config"
CONFIG_DEST="$DOTFILES_REPO/config"

# --- DEKLARASI DATA (Edit di sini jika ingin menambah config) ---
# Format: "Nama_Folder_Asal:Nama_Folder_Tujuan_di_Repo"
CONFIG_FILES=(
    "nvim:nvim"
)

# Format: "Nama_File_Asal:Nama_File_Tujuan_di_Repo"
HOME_FILES=(
    ".bashrc:bashrc"
    ".gitconfig:gitconfig"
)

header() {
    echo -e "${BLUE}${BOLD}==========================================${NC}"
    echo -e "${BLUE}${BOLD}    рџљЂ DOTFILES MANAGER (Default: Restore)${NC}"
    echo -e "${BLUE}${BOLD}==========================================${NC}"
}

# --- FUNGSI RESTORE (DEFAULT) ---
restore() {
    header
    echo -e "${GREEN}[MODE: RESTORE (Repo -> Local)]${NC}"
    
    # 1. Restore .config Folders
    echo -e "\n${BOLD}1. Memulihkan Folder .config${NC}"
    echo "----------------------------------------------------"
    for entry in "${CONFIG_FILES[@]}"; do
        src="${entry%%:*}"; dest="${entry#*:}"
        if [ -d "$CONFIG_DEST/$dest" ]; then
            mkdir -p "$CONFIG_SRC/$src"
            # rsync isi folder repo ke lokal
            rsync -az --delete "$CONFIG_DEST/$dest/" "$CONFIG_SRC/$src/"
            printf "  %-30s ${GREEN}вњ”пёЏ Restored${NC}\n" "$src"
        else
            printf "  %-30s ${RED}вќЊ Missing in Repo${NC}\n" "$dest"
        fi
    done

    # 2. Restore Home Files
    echo -e "\n${BOLD}2. Memulihkan file Home${NC}"
    echo "----------------------------------------------------"
    for entry in "${HOME_FILES[@]}"; do
        src="${entry%%:*}"; dest="${entry#*:}"
        if [ -f "$DOTFILES_REPO/$dest" ]; then
            mkdir -p "$(dirname "$HOME/$src")"
            rsync -az "$DOTFILES_REPO/$dest" "$HOME/$src"
            printf "  %-30s ${GREEN}вњ”пёЏ Restored${NC}\n" "$src"
        else
            printf "  %-30s ${RED}вќЊ Missing in Repo${NC}\n" "$dest"
        fi
    done
    echo -e "\n${GREEN}Selesai! Konfigurasi telah diperbarui.${NC}"
}

# --- FUNGSI BACKUP (TAMBAHAN) ---
backup() {
    header
    echo -e "${YELLOW}[MODE: BACKUP (Local -> Repo)]${NC}"
    echo -e "Pilih lingkup backup:"
    echo -e "1) Backup SEMUA yang terdaftar"
    echo -e "2) Pilih Folder .config tertentu"
    echo -e "3) Pilih File Home tertentu"
    read -p "Masukkan pilihan (1/2/3): " choice

    case $choice in
        1)
            # Backup .config
            echo -e "\n${BLUE}Syncing .config folders...${NC}"
            for entry in "${CONFIG_FILES[@]}"; do
                src="${entry%%:*}"; dest="${entry#*:}"
                if [ -d "$CONFIG_SRC/$src" ]; then
                    mkdir -p "$CONFIG_DEST/$dest"
                    rsync -az --delete "$CONFIG_SRC/$src/" "$CONFIG_DEST/$dest/"
                    printf "  %-30s ${GREEN}вњ”пёЏ Synced${NC}\n" "$src"
                fi
            done
            # Backup Home
            echo -e "\n${BLUE}Syncing Home files...${NC}"
            for entry in "${HOME_FILES[@]}"; do
                src="${entry%%:*}"; dest="${entry#*:}"
                [ -f "$HOME/$src" ] && rsync -az "$HOME/$src" "$DOTFILES_REPO/$dest" && printf "  %-30s ${GREEN}вњ”пёЏ Synced${NC}\n" "$src"
            done
            ;;
        2)
            echo -e "\nDaftar .config yang tersedia:"
            for i in "${!CONFIG_FILES[@]}"; do echo "$i) ${CONFIG_FILES[$i]%%:*}"; done
            read -p "Masukkan nomor (pisahkan spasi): " indices
            for idx in $indices; do
                entry="${CONFIG_FILES[$idx]}"
                src="${entry%%:*}"; dest="${entry#*:}"
                if [ -d "$CONFIG_SRC/$src" ]; then
                    mkdir -p "$CONFIG_DEST/$dest"
                    rsync -az --delete "$CONFIG_SRC/$src/" "$CONFIG_DEST/$dest/"
                    echo -e "  ${GREEN}вњ”пёЏ $src synced${NC}"
                fi
            done
            ;;
        3)
            echo -e "\nDaftar file Home yang tersedia:"
            for i in "${!HOME_FILES[@]}"; do echo "$i) ${HOME_FILES[$i]%%:*}"; done
            read -p "Masukkan nomor (pisahkan spasi): " indices
            for idx in $indices; do
                entry="${HOME_FILES[$idx]}"
                src="${entry%%:*}"; dest="${entry#*:}"
                if [ -f "$HOME/$src" ]; then
                    rsync -az "$HOME/$src" "$DOTFILES_REPO/$dest"
                    echo -e "  ${GREEN}вњ”пёЏ $src synced${NC}"
                fi
            done
            ;;
        *) echo "Batal.";;
    esac
}

# --- LOGIKA EKSEKUSI ---
# Jika argumen pertama adalah "backup", jalankan fungsi backup.
# Jika tidak ada argumen atau argumen apapun selain backup, jalankan restore.
if [ "$1" == "backup" ]; then
    backup
else
    restore
fi
